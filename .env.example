# --- Discord -----------------------------------------------------------------
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CHANNEL_ID=your-channel-id
# Comma-separated Discord user IDs allowed to command the bot (empty = anyone in the channel).
DISCORD_ALLOWED_USERS=703055710791139399

# --- Customer (used to book) -------------------------------------------------
CUSTOMER_NAME=Your Name
CUSTOMER_EMAIL=you@example.com
CUSTOMER_PHONE=+31600000000

# --- Google Calendar ---------------------------------------------------------
GCAL_ENABLED=true
GCAL_CALENDAR_ID=you@example.com
# Preferred (env-only, no host file): base64 of the service-account JSON.
#   base64 -i gcal-sa.json   ->  paste the one-line output here
# GOOGLE_CREDENTIALS_B64=eyJ0eXBlIjoic2Vydmlj...
# OR mount the JSON file and point to it:
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcal-sa.json

# --- Branding ----------------------------------------------------------------
# Icon shown on every Discord embed. Defaults to the salon's site photo.
# To use the cartoon, host it (e.g. public GitHub repo) and set its raw URL:
# BRAND_ICON_URL=https://cdn.jsdelivr.net/gh/JDFS404/knipalert@main/assets/snipalert-bot-icon.png

# --- Scheduling / locale -----------------------------------------------------
TIMEZONE=Europe/Amsterdam
REMINDER_HOUR=9

# --- Optional smart fallback (Claude Haiku) ----------------------------------
# Leave ANTHROPIC_API_KEY empty to stay 100% rule-based + free.
# Set it to enable AI parsing only when the rules can't understand a message.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- SalonHub (defaults are correct for Barbershop Alan) ---------------------
SALONHUB_CLIENT=barbershopalan
SALONHUB_SALON=amsterdam
SALONHUB_TREATMENT=1
SALONHUB_EMPLOYEE=1
